{
  "expo": {
    "name": "Kumva Insights",
    "slug": "IoT-Data-Control-System",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Kumva-New-Logo-D.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Kumva-New-Logo-D.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF1F8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Kumva-New-Logo-D.png",
        "backgroundColor": "#EEF1F8"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/Kumva-New-Logo-D.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font"
    ]
  }
}
